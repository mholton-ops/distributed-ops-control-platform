{
  "name": "@ops/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts src/db/migrate.ts src/db/seed.ts --bundle --platform=node --target=node24 --format=esm --sourcemap --outbase=src --outdir=dist --external:drizzle-orm --external:drizzle-orm/* --external:fastify --external:fastify-type-provider-zod --external:pg --external:zod",
    "start": "node dist/index.js",
    "db:migrate": "node ../../scripts/run-test-database-task.mjs migrate",
    "seed": "node ../../scripts/run-test-database-task.mjs seed",
    "test": "vitest run --exclude **/*.integration.test.ts",
    "test:integration": "vitest run tests/event-service.integration.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@ops/contracts": "0.1.0",
    "@ops/domain": "0.1.0",
    "drizzle-orm": "0.45.2",
    "fastify": "5.10.0",
    "fastify-type-provider-zod": "6.1.0",
    "pg": "8.22.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "@types/pg": "8.20.0",
    "typescript": "5.9.3"
  }
}
